# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# GitHub personal access token — used by /api/fetch-repo to raise the API rate limit
# Public repos only. Read-only scope is sufficient.
GITHUB_TOKEN="ghp_..."

# GitHub OAuth App — enables "Open docs PR" in Document mode (commit generated
# docs back to the user's repo). Register an OAuth App at
# https://github.com/settings/developers with callback:
#   <your-origin>/api/github/callback
# Optional: without these, users can still open a docs PR by pasting a
# fine-grained token (Contents + Pull requests: write).
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
